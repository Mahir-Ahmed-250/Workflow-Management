{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "{src/db/db.json,dist/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index?_original_path=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
